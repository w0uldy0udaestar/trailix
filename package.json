{
  "name": "trailix",
  "version": "0.1.0",
  "description": "Grades the thoroughness of delegated Claude Code work — a rule-based report card with evidence lines, inside your terminal.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "trailix": "dist/bin/trailix.js",
    "trailix-hook": "dist/bin/trailix-hook.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/w0uldy0udaestar/trailix.git"
  },
  "files": [
    "dist/"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "test": "node --test 'test/**/*.test.ts'",
    "typecheck": "tsc --noEmit",
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "prepack": "npm run build"
  },
  "keywords": [
    "claude-code",
    "claude",
    "agent",
    "audit",
    "thoroughness",
    "report-card",
    "cli"
  ],
  "devDependencies": {
    "@types/node": "^26.1.0",
    "typescript": "^6.0.3"
  }
}
